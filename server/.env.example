# このファイルを .env にコピーして値を埋めてください（.env はGitに上げない）

# SESを作成したリージョン（シドニー）
AWS_REGION=ap-southeast-2

# 送信元: SESで「検証済み」のメールアドレスまたはドメインのアドレス
MAIL_FROM=no-reply@example.com

# 受信先: 問い合わせを受け取りたい自分のアドレス
MAIL_TO=kiyose.tablet@gmail.com

# 本番では自分のサイトのオリジンに限定する（例: https://example.com）
ALLOW_ORIGIN=*

# Nodeの待受ポート（nginxからこのポートに転送する）
PORT=3001

# --- 以下はEC2にIAMロールを付けない場合だけ設定 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
